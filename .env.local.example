# === 必須: Gemini ===
# https://aistudio.google.com/app/apikey で発行（無料枠あり）
GEMINI_API_KEY=

# === GitHub バックエンド（編集提案 PR フロー） ===
# 未設定なら /edit から PR は作れず、/pr ページは "未設定" 表示にフォールバック。
# repo スコープの PAT または GitHub App のインストールトークン
GITHUB_TOKEN=
# 対象リポジトリ（既定: afdpfrss / document-agent / main）
GITHUB_REPO_OWNER=afdpfrss
GITHUB_REPO_NAME=document-agent
GITHUB_BASE_BRANCH=main

# === 認証 (Phase 7 / Google OAuth) ===
# AUTH_GOOGLE_ID と AUTH_GOOGLE_SECRET が両方セットされた時のみ認証 ON。
# 未設定なら "認証オフ" モードで誰でも全機能アクセス可（ローカル開発用）。
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# 「編集」ロールに昇格させるメールアドレスの allowlist（カンマ区切り）
EDITOR_EMAILS=

# === MCP コネクタ（リモート MCP サーバ / v2 設計 §4 提供レイヤー） ===
# 文書検索を MCP ツールとして公開するエンドポイント: /api/mcp
# 利用者は自分の Claude にカスタムコネクタとして登録して使う。クエリ時の
# 回答生成 LLM はこのサーバでは呼ばない（推論コストは利用者側の Claude が負担）。
# - search_documents のベクトル検索は上記 GEMINI_API_KEY を再利用する。未設定なら
#   メタデータ駆動の検索のみへ自動フォールバックする。
# - /api/mcp は OAuth 2.1 で保護される。OAuth が有効になるのは AUTH_GOOGLE_ID /
#   AUTH_GOOGLE_SECRET が設定されている時（= アプリ全体の認証 ON）。トークン・認可
#   コード・client_id の署名には上記 AUTH_SECRET を使う。認証が有効になるまで公開
#   デプロイ禁止（社内機密文書が URL を知る全員に露出するため）。
#
# 公開 URL。プロキシ背後で Host ヘッダが当てにならない場合に明示する。未設定なら
# AUTH_URL → リクエストヘッダの順に解決。OAuth の issuer / エンドポイント URL と
# アクセストークンの audience に使われる。
MCP_PUBLIC_URL=
# コネクタを「社内ユーザーのみ」に制限する allowlist（どちらか／両方を設定）。
# - MCP_ALLOWED_EMAIL_DOMAINS: 許可するメールドメイン（カンマ区切り。例: example.co.jp）
# - MCP_ALLOWED_EMAILS: 許可する個別メールアドレス（カンマ区切り）
# 両方とも未設定だと Google 認証を通った任意のアカウントが利用可能になるため、
# 本番では最低どちらか一方を必ず設定して組織内に閉じること。
MCP_ALLOWED_EMAIL_DOMAINS=
MCP_ALLOWED_EMAILS=

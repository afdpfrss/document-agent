# === 必須: Gemini ===
# https://aistudio.google.com/app/apikey で発行（無料枠あり）
GEMINI_API_KEY=

# === GitHub バックエンド（編集提案 PR フロー） ===
# 未設定なら /edit から PR は作れず、/pr ページは "未設定" 表示にフォールバック。
# repo スコープの PAT または GitHub App のインストールトークン
GITHUB_TOKEN=
# 対象リポジトリ（既定: afdpfrss / document-agent / main）
GITHUB_REPO_OWNER=afdpfrss
GITHUB_REPO_NAME=document-agent
GITHUB_BASE_BRANCH=main

# === 認証 (Phase 7 / Google OAuth) ===
# AUTH_GOOGLE_ID と AUTH_GOOGLE_SECRET が両方セットされた時のみ認証 ON。
# 未設定なら "認証オフ" モードで誰でも全機能アクセス可（ローカル開発用）。
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# 「編集」ロールに昇格させるメールアドレスの allowlist（カンマ区切り）
EDITOR_EMAILS=

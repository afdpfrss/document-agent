{
  "name": "document-agent",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "ingest": "node scripts/ingest.mjs",
    "propose-edit": "node scripts/propose-edit.mjs",
    "validate:corpus": "node scripts/validate-corpus.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "check:sod": "node scripts/check-separation-of-duties.mjs",
    "build:corpus": "node scripts/build-corpus.mjs",
    "postinstall": "node scripts/build-corpus.mjs",
    "cf:build": "node scripts/build-corpus.mjs && opennextjs-cloudflare build",
    "cf:preview": "npm run cf:build && opennextjs-cloudflare preview",
    "cf:deploy": "npm run cf:build && opennextjs-cloudflare deploy",
    "cf:typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@monaco-editor/react": "^4.7.0",
    "gray-matter": "^4.0.3",
    "next": "16.2.6",
    "next-auth": "^5.0.0-beta.31",
    "octokit": "^5.0.5",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.11",
    "@tailwindcss/postcss": "^4",
    "@types/hast": "^3.0.4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "mammoth": "^1.12.0",
    "pdfjs-dist": "^5.7.284",
    "tailwindcss": "^4",
    "turndown": "^7.2.4",
    "typescript": "^5",
    "vitest": "^4.1.6",
    "wrangler": "^4.93.0",
    "xlsx": "^0.18.5"
  }
}
